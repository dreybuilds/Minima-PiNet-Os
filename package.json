{
  "name": "pinet-web3-os",
  "version": "1.0.35",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview --host",
    "lint": "tsc --noEmit",
    "deploy": "npm install && npm run build && npm run preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && tsc -p electron && electron .\"",
    "electron:build": "tsc -p electron && electron-builder"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "adm-zip": "^0.5.16",
    "electron-store": "^8.2.0",
    "express": "^5.2.1",
    "motion": "^12.35.2",
    "node-pty": "^1.0.0",
    "os-utils": "^0.0.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "systeminformation": "^5.23.4",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.pinetos.desktop",
    "productName": "PiNetOS-Desktop",
    "directories": {
      "output": "dist-electron-build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "System"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}